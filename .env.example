# ============================================
# Flight Price Monitor — Environment Variables
# ============================================
# Copy this to .env and fill in your values

# SerpAPI (https://serpapi.com — sign up and grab your key from the dashboard)
# Free tier: 250 searches/month | $25/mo: 1,000 searches
SERPAPI_KEY=your_serpapi_key

# Telegram Bot (talk to @BotFather on Telegram to create a bot)
# Then message your bot and visit:
# https://api.telegram.org/bot<TOKEN>/getUpdates
# to find your chat_id
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Cron schedule (default: every 3 hours)
CRON_SCHEDULE=0 */3 * * *

# How many date pairs to check per cron run (each pair = 1 API call)
# Free tier budget: 250/month ÷ 30 days ÷ 8 runs/day ≈ ~1 per run
# $25 tier budget: 1000/month ÷ 30 days ÷ 8 runs/day ≈ ~4 per run
BATCH_SIZE=3
